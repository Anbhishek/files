# Copy this file to ".env" and fill in real values.
# Without this file, emails/SMS are just printed to the console -- the app still works.

# --- Email (SMTP) -- e.g. Gmail: smtp.gmail.com, port 587, use an "app password" ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=abhishekna02@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=abhishekna02@gmail.com

# --- SMS via Twilio (optional, requires a Twilio account) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
